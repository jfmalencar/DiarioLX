# === USER MANAGEMENT REQUESTS ===
# DiarioLX User Management API Tests
# Invite Tokens: Authorization: Invite {{inviteToken}}
# Session Tokens: Cookie: token={{sessionToken}}
# NOTE: Only one Cookie header with ONE token value per request

# === VARIABLES ===
@baseUrl = http://localhost:8180
@adminInviteToken = SUPER-ADMIN-INVITE

# Admin credentials
@adminUsername = admin
@adminEmail = admin.email@diariolx.pt
@adminPassword = SecurePass123!
@adminFirstName = Admin
@adminLastName = User

# Test user credentials
@testUsername = testuser
@testEmail = testuser@diariolx.pt
@testPassword = TestPass123!
@testFirstName = Test
@testLastName = User

# User IDs (populated by requests)
@adminId = 1
@testUserId = 2

### ===== STEP 1: CREATE ADMIN USER WITH INVITE =====

### Create admin user (Invite token in Authorization: Invite header)
POST {{baseUrl}}/user/signup
Content-Type: application/json
Authorization: Invite {{adminInviteToken}}

{
  "username": "{{adminUsername}}",
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}",
  "fName": "{{adminFirstName}}",
  "lName": "{{adminLastName}}"
}

> {%
  if (response.status === 201) {
    client.global.set("adminId", response.body.userId);
  }
%}

### ===== STEP 2: ADMIN LOGIN =====

### Admin login
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{
  "username": "jlobato",
  "password": "Julianne@1"
}

> {%
  if (response.status === 202) {
    client.global.set("adminToken", response.body.token);
  }
%}

### ===== STEP 3: CREATE INVITES (AS ADMIN) =====

### Create EDITOR invite
POST {{baseUrl}}/api/user/admin/create-invite
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "role": "EDITOR"
}

> {%
  if (response.status === 201) {
    client.global.set("editorInviteToken", response.body.inviteToken);
  }
%}

###
### Create CONTRIBUTOR invite
POST {{baseUrl}}/user/admin/create-invite
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "role": "CONTRIBUTOR"
}

> {%
  if (response.status === 201) {
    client.global.set("contributorInviteToken", response.body.inviteToken);
  }
%}

###
### Create CONTRIBUTOR invite
POST {{baseUrl}}/user/admin/create-invite
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "role": "CONTRIBUTOR"
}

> {%
    if (response.status === 201) {
        client.global.set("contributorInviteToken2", response.body.inviteToken);
    }
%}

