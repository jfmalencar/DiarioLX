### ===== STEP 9: UPDATE WITH ERROR CASES =====

### Try to update with email that already exists (should fail - 409 CONFLICT)
POST {{baseUrl}}/user/update
Content-Type: application/json
Cookie: token={{testToken}}

{
  "username": null,
  "email": "{{adminEmail}}",
  "password": null,
  "fName": null,
  "lName": null,
  "bio": null,
  "profilePictureURL": null
}

###
### Try to update with invalid email format (should fail - 400 BAD_REQUEST)
POST {{baseUrl}}/user/update
Content-Type: application/json
Cookie: token={{testToken}}

{
  "username": null,
  "email": "invalidemail",
  "password": null,
  "fName": null,
  "lName": null,
  "bio": null,
  "profilePictureURL": null
}

###
### Try to update with weak password (should fail - 400 BAD_REQUEST)
POST {{baseUrl}}/user/update
Content-Type: application/json
Cookie: token={{testToken}}

{
  "username": null,
  "email": null,
  "password": "weak",
  "fName": null,
  "lName": null,
  "bio": null,
  "profilePictureURL": null
}

###
### Try to update with empty username (should fail - 400 BAD_REQUEST)
POST {{baseUrl}}/user/update
Content-Type: application/json
Cookie: token={{testToken}}

{
  "username": "",
  "email": null,
  "password": null,
  "fName": null,
  "lName": null,
  "bio": null,
  "profilePictureURL": null
}

###
### Try to update with duplicate username (should fail - 409 CONFLICT)
POST {{baseUrl}}/user/update
Content-Type: application/json
Cookie: token={{testToken}}

{
  "username": "{{adminUsername}}",
  "email": null,
  "password": null,
  "fName": null,
  "lName": null,
  "bio": null,
  "profilePictureURL": null
}

### ===== STEP 10: ADMIN OPERATIONS - DEACTIVATE USER =====

### Deactivate a user (as admin)
POST {{baseUrl}}/user/admin/deactivate-user
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "id": {{editorUserId}}
}

###
### Try to deactivate user without admin privileges (should fail - 403 FORBIDDEN)
POST {{baseUrl}}/user/admin/deactivate-user
Content-Type: application/json
Cookie: token={{testToken}}

{
  "id": {{thirdUserId}}
}

###
### Try to deactivate non-existent user (should fail - 404 NOT_FOUND)
POST {{baseUrl}}/user/admin/deactivate-user
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "id": 9999
}

### ===== STEP 11: ADMIN OPERATIONS - REMOVE USER =====

### Create user to remove
POST {{baseUrl}}/user/signup
Content-Type: application/json
Authorization: Invite {{contributorInviteToken}}

{
  "username": "usertoremove",
  "email": "remove@diariolx.pt",
  "password": "RemovePass123!",
  "fName": "Remove",
  "lName": "Me"
}

> {%
  if (response.status === 201) {
    client.global.set("userToRemoveId", response.body.userId);
  }
%}

###
### Remove user permanently (as admin)
POST {{baseUrl}}/user/admin/remove-user
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "id": {{userToRemoveId}}
}

###
### Try to remove user without admin privileges (should fail - 403 FORBIDDEN)
POST {{baseUrl}}/user/admin/remove-user
Content-Type: application/json
Cookie: token={{testToken}}

{
  "id": {{thirdUserId}}
}

###
### Try to remove non-existent user (should fail - 404 NOT_FOUND)
POST {{baseUrl}}/user/admin/remove-user
Content-Type: application/json
Cookie: token={{adminToken}}

{
  "id": 9999
}

### ===== STEP 12: LOGIN ERROR CASES =====

### Login with invalid credentials - wrong password (should fail - 401 UNAUTHORIZED)
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "username": "{{adminUsername}}",
  "password": "WrongPassword123!"
}

###
### Login with invalid credentials - non-existent user (should fail - 401 UNAUTHORIZED)
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "username": "nonexistentuser",
  "password": "AnyPassword123!"
}

###
### Login with deactivated account (should fail - 403 FORBIDDEN)
POST {{baseUrl}}/user/login
Content-Type: application/json

{
  "username": "editoruser",
  "password": "EditorPass123!"
}

