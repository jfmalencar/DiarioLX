        {
          "name": "Get Admin Info",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/{{adminId}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "{{adminId}}"]
            }
          }
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "token={{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/all?offset=0&limit=10&deactivated=true",
              "host": ["{{baseUrl}}"],
              "path": ["user", "all"],
              "query": [
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "deactivated",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
