            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/admin/deactivate-user",
              "host": ["{{baseUrl}}"],
              "path": ["user", "admin", "deactivate-user"]
            }
          }
        },
        {
          "name": "Remove User",
